# ============================================
# VARIABLES DE ENTORNO PARA DOKPLOY - BACKEND
# ============================================
# Copia estas variables en tu proyecto backend en Dokploy
# ⚠️ IMPORTANTE: Reemplazar valores entre < > con tus datos reales

# Entorno
NODE_ENV=production
PORT=5000

# Base de Datos PostgreSQL
# ✅ Esta URL ya está correcta según tu configuración
DATABASE_URL=postgresql://postgres:Humbug0809@chpc-database-sev7k6:5432/chpc-webpage

# JWT Secrets 
# ⚠️ CAMBIAR ESTOS VALORES EN PRODUCCIÓN
# Genera valores seguros con: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=<GENERAR-VALOR-SEGURO-AQUI>
JWT_REFRESH_SECRET=<GENERAR-VALOR-SEGURO-AQUI>

# CORS - Orígenes Permitidos
# ⚠️ Para Easypanel: https://chpc-web-frontend.qut3sg.easypanel.host
# ⚠️ Para dominio personalizado: https://www.tudominio.com
# Formato: separar múltiples orígenes con comas (sin espacios)
CORS_ORIGIN=https://chpc-web-frontend.qut3sg.easypanel.host,https://www.tudominio.com,https://tudominio.com

# URL del Frontend
# ⚠️ Para Easypanel usa:
FRONTEND_URL=https://chpc-web-frontend.qut3sg.easypanel.host

# Directorio de archivos multimedia
# ⚠️ IMPORTANTE: Debes configurar un volumen en Dokploy para que este directorio persista
# 
# En Dokploy > Backend > Volumes / Mounts:
#   - Mount Type: Volume Mount
#   - Host Path: chpc-multimedia
#   - Mount Path: /mnt/multimedia
#
# Las imágenes se guardarán en: /mnt/multimedia/productos/
UPLOAD_DIR=/mnt/multimedia

# ============================================
# EJEMPLO CON DOMINIO PERSONALIZADO DE GODADDY
# ============================================
# Si tu dominio es www.ejemplo.com:
#
# CORS_ORIGIN=https://www.ejemplo.com,https://ejemplo.com,https://chpc-frontend-rrp6aj-18e970-45-88-188-111.traefik.me
# FRONTEND_URL=https://www.ejemplo.com
