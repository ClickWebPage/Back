// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum OrderStatus {
  PENDING
  PAID
  SHIPPED
  COMPLETED
  CANCELLED
}

enum EstadoPedido {
  PENDIENTE
  EN_TRAMITE
  ATENDIDO
  CANCELADO
}

enum PaymentMethod {
  CASH
  CARD
  TRANSFER
}

